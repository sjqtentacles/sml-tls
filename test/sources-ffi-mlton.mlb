(* FFI test build (MLton). Loads the base library, then the MLton-specific
   CryptoFfi implementation (_import) and the cross-impl byte-identity
   tests. Linked against the libsodium shim by the Makefile's test-ffi
   target. NOT used by Poly/ML (see sources-ffi-poly.mlb). *)

$(SML_LIB)/basis/basis.mlb

../lib/github.com/sjqtentacles/sml-tls/sources.mlb

(* Constant-time crypto FFI shim: MLton _import implementation. *)
../lib/github.com/sjqtentacles/sml-crypto-ffi/crypto_ffi.sig
../lib/github.com/sjqtentacles/sml-crypto-ffi/crypto_ffi_mlton.sml

harness.sml
ffi.sml
ffi-entry.sml
main.sml
